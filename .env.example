# Kopieer dit bestand naar .env.local en vul de waarden in.
# Zie README.md voor uitleg per variabele.

# ── Supabase (verplicht) ─────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── AI & e-mail ──────────────────────────────────────────────
ANTHROPIC_API_KEY=
RESEND_API_KEY=

# ── OAuth-koppelingen (optioneel per provider) ───────────────
OAUTH_STATE_SECRET=
GOOGLE_FIT_CLIENT_ID=
GOOGLE_FIT_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=

# ── Telegram-assistent (optioneel) ───────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# ── Stripe (optioneel — zonder keys valt betalen terug op contact) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price-ID's van de terugkerende prijzen (per gebruiker/maand) in Stripe:
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROEI=

# ── Overig (optioneel) ───────────────────────────────────────
GITHUB_TOKEN=
USDA_API_KEY=
INTERNAL_API_KEY=

# ─── LifeOS (persoonlijk, founder-only) ─────────────────────────────────────
# LifeOS-data leeft in een EIGEN Supabase-project (niet de B2B-database). Deze
# app praat er server-side met de service-role mee, alleen achter de founder-gate.
LIFEOS_SUPABASE_URL=https://bbklogjersviaoocgrve.supabase.co
LIFEOS_USER_ID=67b0a700-3f1d-425e-9646-98c237e34fd7
# GEHEIM — vul jij: Supabase → lifeos-project → Settings → API → Legacy → service_role.
LIFEOS_SERVICE_ROLE_KEY=

# ─── LifeOS via Telegram (functie 4: Vita onderweg) ─────────────────────────
# Een EIGEN, APARTE bot (los van de Fit Factory-assistent hierboven op /api/telegram).
# Je stuurt hem onderweg een spraakmemo of tekst; die wordt een taak, notitie of
# afspraak op de vaste LIFEOS_USER_ID hierboven. De webhook staat op (gebruikt
# NEXT_PUBLIC_APP_URL uit de App-sectie bovenaan):
#   ${NEXT_PUBLIC_APP_URL}/api/lifeos/telegram/webhook
#
# Anders dan de andere LifeOS-routes heeft deze GEEN founder-sessie om tegen te
# gate'n (Telegram pusht server-to-server). De beveiliging is daarom: (1) het secret
# in constante tijd, (2) de chat-id-allowlist hieronder, (3) een snelheidslimiet van
# 20 berichten per minuut per chat. Leeg secret = de webhook wijst alles af
# (fail-closed): een publieke route zonder secret is een open deur.
#
# LET OP: de allowlist is sinds juli 2026 óók fail-closed. Staat hij leeg, dan doet
# de bot NIETS — ook niet met een geldig secret. Zie LIFEOS_TELEGRAM_ALLOWED_CHAT_ID.
#
# Bewust EIGEN keys (LIFEOS_TELEGRAM_*), los van de Fit Factory-bot: een Telegram-bot
# kan zijn webhook maar naar ÉÉN URL laten wijzen, dus de twee bots hebben elk hun
# eigen token, secret en webhook. Niets hier deelt met de assistent-sectie bovenaan.

# Bot-token van @BotFather (Telegram → /newbot). Geheim: volledige controle over de
# bot. Nooit loggen, nooit met NEXT_PUBLIC_-prefix.
LIFEOS_TELEGRAM_BOT_TOKEN=

# Gedeeld geheim dat Telegram in de header `X-Telegram-Bot-Api-Secret-Token` zet; de
# webhook vergelijkt het in constante tijd en geeft 401 bij mismatch.
#   Genereer: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# Koppel de bot aan deze webhook met setWebhook (voer één keer uit, vervang de
# placeholders). `secret_token` MOET exact gelijk zijn aan LIFEOS_TELEGRAM_WEBHOOK_SECRET:
#   curl -X POST "https://api.telegram.org/bot<LIFEOS_TELEGRAM_BOT_TOKEN>/setWebhook" \
#     -H "Content-Type: application/json" \
#     -d '{"url":"<NEXT_PUBLIC_APP_URL>/api/lifeos/telegram/webhook","secret_token":"<LIFEOS_TELEGRAM_WEBHOOK_SECRET>","allowed_updates":["message"]}'
LIFEOS_TELEGRAM_WEBHOOK_SECRET=

# VERPLICHT: allowlist van chat-id's die de bot mogen bedienen (komma-gescheiden).
# Het secret bewijst "dit komt van Telegram", NIET "dit komt van jou" — wie de
# bot-naam kent, kan hem óók aanschrijven. Deze lijst sluit dat af tot je eigen chat(s).
#
# LEEG = DE BOT DOET NIETS. Dat is met opzet: achter deze deur schrijft LifeOS
# AUTONOOM afspraken in je échte Google-agenda (zonder klik, alleen een
# vertrouwensdrempel als rem). Eén lek secret + een lege lijst = een vreemde in je
# agenda. Een dichte deur hoort niet vanzelf open te gaan.
#
# Kip-ei: je chat-id ken je pas ná je eerste bericht. Daarvoor is de leer-modus —
# een expliciete, tijdelijke escape:
#
#   1. LIFEOS_TELEGRAM_ALLOWED_CHAT_ID=leer-modus
#   2. Stuur de bot één bericht. Hij meldt je chat-id terug en voert VERDER NIETS
#      uit: geen taak, geen notitie, geen afspraak, geen AI-aanroep.
#   3. LIFEOS_TELEGRAM_ALLOWED_CHAT_ID=<jouw id>   ← haal "leer-modus" weg!
#
# Tussenstap mag: `leer-modus,123456` laat jouw chat normaal werken terwijl elke
# andere chat alleen zijn id terugkrijgt. Vergeet 'm daarna niet weg te halen.
# Alternatief zonder leer-modus: stuur een bericht aan @userinfobot op Telegram.
LIFEOS_TELEGRAM_ALLOWED_CHAT_ID=

# ─── De dagbriefing (Vita tikt je aan) ──────────────────────────────────────
# Waar de ochtendbriefing heen gaat. Meestal hetzelfde id als hierboven, maar
# bewust een eigen var: de allowlist zegt wie er IN mag praten, dit zegt waar het
# UIT gaat. Die twee gelijkstellen werkt tot je ooit een tweede chat toelaat.
#
# Leeg = geen briefing. Dat is geen storing maar een keuze, en Vita's kaart zegt
# dan eerlijk "Uit mezelf tik ik je nu nog niet aan" — hij keyt op de tabel
# `vita_briefingen` (wat er ÉCHT bezorgd is), niet op het bestaan van deze var.
LIFEOS_TELEGRAM_CHAT_ID=

# ─── Cron ───────────────────────────────────────────────────────────────────
# Beveiligt /api/cron/lifeos-briefing. Fail-closed: leeg = de route wijst alles
# af. Dezelfde waarde moet als GitHub-secret staan (repo → Settings → Secrets →
# Actions), want .github/workflows/lifeos-briefing.yml roept 'm daarmee aan.
#
# Zelf genereren: `openssl rand -hex 32`
#
# LET OP: een cron die in de codebase staat is niet een cron die draait. Zet het
# secret op BEIDE plekken en draai de workflow één keer handmatig (Actions → Run
# workflow) — pas als er een bericht binnenkomt is de belofte waar.
CRON_SECRET=

# ─── Tijdzone ───────────────────────────────────────────────────────────────
# HARDE EIS voor de server: Europe/Amsterdam.
#
# `vrije-blokken.ts` bepaalt het werkvenster (08:00-20:00) met lokale `setHours`.
# Staat de server op UTC, dan schuift dat venster 's zomers twee uur op en plant
# het focusblok je diepe werk om 06:00. Lokaal op Windows staat dit meestal al
# goed; op Render moet je het zetten.
TZ=Europe/Amsterdam

# ─── Transcriptie (spraakmemo → tekst) ──────────────────────────────────────
# OpenAI Whisper zet een Telegram-spraakmemo om in tekst voordat het intentiebrein
# hem classificeert. Leeg = spraakmemo's falen met een duidelijke fout (geen stille
# leegte); tekstberichten blijven gewoon werken.
#   platform.openai.com/api-keys
OPENAI_API_KEY=
