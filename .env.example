# Kopieer dit bestand naar .env.local en vul de waarden in.
# Zie README.md voor uitleg per variabele.

# ── Supabase (verplicht) ─────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── AI & e-mail ──────────────────────────────────────────────
ANTHROPIC_API_KEY=
RESEND_API_KEY=

# ── OAuth-koppelingen (optioneel per provider) ───────────────
OAUTH_STATE_SECRET=
GOOGLE_FIT_CLIENT_ID=
GOOGLE_FIT_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=

# ── Telegram-assistent (optioneel) ───────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# ── Stripe (optioneel — zonder keys valt betalen terug op contact) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price-ID's van de terugkerende prijzen (per gebruiker/maand) in Stripe:
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROEI=

# ── Overig (optioneel) ───────────────────────────────────────
GITHUB_TOKEN=
USDA_API_KEY=
INTERNAL_API_KEY=
